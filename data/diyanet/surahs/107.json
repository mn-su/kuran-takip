{
  "id": 107,
  "name": "الماعون",
  "translation": "Maûn",
  "transliteration": "maun",
  "nuzul": 17,
  "description": "Mekke döneminde inmiştir. 7 âyettir. Mâ’ûn, yardım ve zekât demektir.",
  "total_verses": 7,
  "verses": [
    {
      "id": 1,
      "text": "",
      "translation": "Gördün mü dini yalan sayanı?"
    },
    {
      "id": 2,
      "text": "",
      "translation": "İşte odur yetimi itip kakan;"
    },
    {
      "id": 3,
      "text": "",
      "translation": "Ve yoksula yedirmeyi özendirmeyen!"
    },
    {
      "id": 4,
      "text": "",
      "translation": "Vay haline o namaz kılanların ki,"
    },
    {
      "id": 5,
      "text": "",
      "translation": "Onlar namazlarının özünden uzaktırlar."
    },
    {
      "id": 6,
      "text": "",
      "translation": "Onlar halka gösteriş yaparlar."
    },
    {
      "id": 7,
      "text": "",
      "translation": "Hayra da engel olurlar."
    }
  ]
}