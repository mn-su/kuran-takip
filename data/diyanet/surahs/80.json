{
  "id": 80,
  "name": "عبس",
  "translation": "Abese",
  "transliteration": "abese",
  "nuzul": 24,
  "description": "Mekke döneminde inmiştir. 42 âyettir. Sûre, adını birinci âyetteki “abese” fiilindenalmıştır. “Abese”, “yüzünü ekşitti” demektir. Sûrede başlıca, itikat, peygamberlik,Allah’ın kudreti ve kıyamet hâlleri konu edilmektedir",
  "total_verses": 42,
  "verses": [
    {
      "id": 1,
      "text": "",
      "translation": "Yüzünü ekşitip başını çevirdi."
    },
    {
      "id": 2,
      "text": "",
      "translation": "Görme engelli o kişi geldi diye."
    },
    {
      "id": 3,
      "text": "",
      "translation": "Ama (ey Peygamber!) Sen nereden bileceksin, belki o kendini arındıracaktı."
    },
    {
      "id": 4,
      "text": "",
      "translation": "Yahut o bir öğüt alacak, bu öğüt kendisine fayda verecekti."
    },
    {
      "id": 5,
      "text": "",
      "translation": "Sen ise kendini her bakımdan ihtiyaçsız görenle ilgileniyorsun."
    },
    {
      "id": 6,
      "text": "",
      "translation": "Sen ise kendini her şeye yeterli görenle ilgileniyorsun."
    },
    {
      "id": 7,
      "text": "",
      "translation": "Onun arınmamasından sen sorumlu tutulmayacaksın ki!"
    },
    {
      "id": 8,
      "text": "",
      "translation": "Gönlünde Allah korkusu taşıyarak koşup sana geleni umursamıyorsun!"
    },
    {
      "id": 9,
      "text": "",
      "translation": "Ama gönlünde Allah korkusu taşıyarak koşup sana gelenle ilgilenmiyorsun!"
    },
    {
      "id": 10,
      "text": "",
      "translation": "Ama gönlünde Allah korkusu taşıyarak koşup sana gelenle ilgilenmiyorsun!"
    },
    {
      "id": 11,
      "text": "",
      "translation": "Hayır! Şüphesiz bu ayetler birer öğüttür."
    },
    {
      "id": 12,
      "text": "",
      "translation": "Dileyen ondan öğüt alır."
    },
    {
      "id": 13,
      "text": "",
      "translation": "O, mukaddes sayfalardadır;"
    },
    {
      "id": 14,
      "text": "",
      "translation": "Yüce makamlara kaldırılmış, tertemiz sayfalarda."
    },
    {
      "id": 15,
      "text": "",
      "translation": "Seçkin ve erdemli elçilerin ellerinde."
    },
    {
      "id": 16,
      "text": "",
      "translation": "Seçkin ve erdemli elçilerin ellerinde."
    },
    {
      "id": 17,
      "text": "",
      "translation": "Kahrolası o insan! Ne kadar da inkarcı!"
    },
    {
      "id": 18,
      "text": "",
      "translation": "(Bir düşünse) Allah onu neden yarattı?"
    },
    {
      "id": 19,
      "text": "",
      "translation": "Bir spermden yarattı da ona şekil verdi."
    },
    {
      "id": 20,
      "text": "",
      "translation": "Sonra ona yolu kolaylaştırdı."
    },
    {
      "id": 21,
      "text": "",
      "translation": "Nihayet onun canını aldı ve kabre koydu."
    },
    {
      "id": 22,
      "text": "",
      "translation": "Sonra dilediği bir vakitte onu yeniden diriltecek."
    },
    {
      "id": 23,
      "text": "",
      "translation": "Hayır! İnsan, Allah’ın emrettiğini yapmadı."
    },
    {
      "id": 24,
      "text": "",
      "translation": "İnsan yediğine bir bakıp düşünsün!"
    },
    {
      "id": 25,
      "text": "",
      "translation": "Biz bolca su indirdik."
    },
    {
      "id": 26,
      "text": "",
      "translation": "Sonra toprağı uygun şekilde yardık."
    },
    {
      "id": 27,
      "text": "",
      "translation": "Oradan ekinler bitirdik."
    },
    {
      "id": 28,
      "text": "",
      "translation": "Üzüm bağları, sebzeler;"
    },
    {
      "id": 29,
      "text": "",
      "translation": "Zeytin ve hurma ağaçları;"
    },
    {
      "id": 30,
      "text": "",
      "translation": "Gür ağaçlı bahçeler;"
    },
    {
      "id": 31,
      "text": "",
      "translation": "Meyveler ve çayırlar;"
    },
    {
      "id": 32,
      "text": "",
      "translation": "Sizin ve hayvanlarınızın yararlanması için."
    },
    {
      "id": 33,
      "text": "",
      "translation": "Kulakları sağır eden o ses geldiğinde,"
    },
    {
      "id": 34,
      "text": "",
      "translation": "İşte o gün kişi kardeşinden, annesinden, babasından, eşinden ve çocuklarından kaçar."
    },
    {
      "id": 35,
      "text": "",
      "translation": "İşte o gün kişi kardeşinden, annesinden, babasından, eşinden ve çocuklarından kaçar."
    },
    {
      "id": 36,
      "text": "",
      "translation": "İşte o gün kişi kardeşinden, annesinden, babasından, eşinden ve çocuklarından kaçar."
    },
    {
      "id": 37,
      "text": "",
      "translation": "O gün onlardan her birinin işi başından aşkındır."
    },
    {
      "id": 38,
      "text": "",
      "translation": "O gün birtakım yüzler parıldar;"
    },
    {
      "id": 39,
      "text": "",
      "translation": "Güleçtir, müjde almıştır."
    },
    {
      "id": 40,
      "text": "",
      "translation": "Birtakım yüzler de o gün toza toprağa bürünmüş;"
    },
    {
      "id": 41,
      "text": "",
      "translation": "Kapkara kesilmiştir."
    },
    {
      "id": 42,
      "text": "",
      "translation": "İşte bunlar inkarcılardır, günahkarlardır."
    }
  ]
}