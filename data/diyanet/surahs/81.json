{
  "id": 81,
  "name": "التكوير",
  "translation": "Tekvîr",
  "transliteration": "tekvir",
  "nuzul": 7,
  "description": "Mekke döneminde inmiştir. 29 âyettir. Sûre, adını birinci âyette geçen “küvviret”fiilinin mastarından almıştır. Tekvîr, dürmek demektir. Sûrede başlıca, kıyamet, vahiy ve peygamberlik konuları ele alınmaktadır.",
  "total_verses": 29,
  "verses": [
    {
      "id": 1,
      "text": "",
      "translation": "Güneş dürülüp karardığında;"
    },
    {
      "id": 2,
      "text": "",
      "translation": "Yıldızlar dökülüp söndüğünde;"
    },
    {
      "id": 3,
      "text": "",
      "translation": "Dağlar sökülüp yürütüldüğünde;"
    },
    {
      "id": 4,
      "text": "",
      "translation": "Doğuracak develer başı boş bırakıldığında;"
    },
    {
      "id": 5,
      "text": "",
      "translation": "Yabani hayvanlar toplanıp bir araya getirildiğinde;"
    },
    {
      "id": 6,
      "text": "",
      "translation": "Denizler kaynatıldığında;"
    },
    {
      "id": 7,
      "text": "",
      "translation": "İnsanlar (amelleriyle) eşleştirilip (buna göre) şekillendirildiğinde;"
    },
    {
      "id": 8,
      "text": "",
      "translation": "Diri diri gömülen kıza hangi suçundan dolayı öldürüldüğü sorulduğunda;"
    },
    {
      "id": 9,
      "text": "",
      "translation": "Diri diri gömülen kıza hangi suçundan dolayı öldürüldüğü sorulduğunda;"
    },
    {
      "id": 10,
      "text": "",
      "translation": "Defterler ortaya serildiğinde;"
    },
    {
      "id": 11,
      "text": "",
      "translation": "Gökyüzü sıyrılıp açıldığında;"
    },
    {
      "id": 12,
      "text": "",
      "translation": "Cehennem ateşi harlatıldığında;"
    },
    {
      "id": 13,
      "text": "",
      "translation": "Cennet yaklaştırıldığında;"
    },
    {
      "id": 14,
      "text": "",
      "translation": "Kişi neler yaptığını öğrenmiş olacaktır."
    },
    {
      "id": 15,
      "text": "",
      "translation": "Hayır hayır! Yörüngelerinde akıp giderek doğan ve batan yıldızlara andolsun!"
    },
    {
      "id": 16,
      "text": "",
      "translation": "Hayır! Hayır! Yörüngelerinde akıp giderek doğan ve batan yıldızlara andolsun!"
    },
    {
      "id": 17,
      "text": "",
      "translation": "Kararmakta olan geceye andolsun!"
    },
    {
      "id": 18,
      "text": "",
      "translation": "Ağarmakta olan sabaha andolsun ki,"
    },
    {
      "id": 19,
      "text": "",
      "translation": "O Kur’an gerçekten değerli, güçlü ve arşın sahibi katında itibarlı bir elçinin sözüdür."
    },
    {
      "id": 20,
      "text": "",
      "translation": "O Kur’an gerçekten değerli, güçlü ve arşın sahibi katında itibarlı, bir elçinin sözüdür."
    },
    {
      "id": 21,
      "text": "",
      "translation": "(Elçi) orada saygın ve güvenilirdir."
    },
    {
      "id": 22,
      "text": "",
      "translation": "Bu kadar beraber yaşadığınız kişi kesinlikle mecnun değildir."
    },
    {
      "id": 23,
      "text": "",
      "translation": "Andolsun ki onu (vahiy meleğini) apaçık ufukta görmüştür."
    },
    {
      "id": 24,
      "text": "",
      "translation": "O, gayba ait bilgileri sizden esirgemez."
    },
    {
      "id": 25,
      "text": "",
      "translation": "O, lanetlenmiş şeytanın sözü değildir."
    },
    {
      "id": 26,
      "text": "",
      "translation": "Öyleyse nereye gidiyorsunuz?"
    },
    {
      "id": 27,
      "text": "",
      "translation": "O herkes için bir öğüttür;"
    },
    {
      "id": 28,
      "text": "",
      "translation": "Özellikle sizden doğru yolda gitmek isteyenler için."
    },
    {
      "id": 29,
      "text": "",
      "translation": "Fakat alemlerin rabbi Allah dilemedikçe siz (hiçbir şey) dileyemezsiniz!"
    }
  ]
}