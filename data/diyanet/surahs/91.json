{
  "id": 91,
  "name": "الشمس",
  "translation": "Şems",
  "transliteration": "sems",
  "nuzul": 26,
  "description": "Mekke döneminde inmiştir. 15 âyettir. Sûre, adını birinci âyetteki “eş-Şems”kelimesinden almıştır. Şems, güneş demektir",
  "total_verses": 15,
  "verses": [
    {
      "id": 1,
      "text": "",
      "translation": "Yemin olsun, güneşe ve kuşluğuna;"
    },
    {
      "id": 2,
      "text": "",
      "translation": "Işığı onun ardından geldiğinde aya;"
    },
    {
      "id": 3,
      "text": "",
      "translation": "Onu (dünyayı) aydınlattığında gündüze;"
    },
    {
      "id": 4,
      "text": "",
      "translation": "Onu karanlıkla örttüğünde geceye;"
    },
    {
      "id": 5,
      "text": "",
      "translation": "Göğe ve onu kuran kudrete;"
    },
    {
      "id": 6,
      "text": "",
      "translation": "Yere ve onu yayıp döşeyene;"
    },
    {
      "id": 7,
      "text": "",
      "translation": "Nefse ve ona düzen verene;"
    },
    {
      "id": 8,
      "text": "",
      "translation": "Ona kötü ve iyi olma yeteneklerini yerleştirene ki,"
    },
    {
      "id": 9,
      "text": "",
      "translation": "Nefsini arındıran elbette kurtuluşa ermiştir."
    },
    {
      "id": 10,
      "text": "",
      "translation": "Onu kötülüklere boğan da ziyan etmiştir."
    },
    {
      "id": 11,
      "text": "",
      "translation": "Semud kavmi, hak tanımazlığı yüzünden (peygamberini) yalanladı."
    },
    {
      "id": 12,
      "text": "",
      "translation": "En azılısı cüretle ileri atıldığında;"
    },
    {
      "id": 13,
      "text": "",
      "translation": "Allah’ın elçisi onlara, “Allah’ın (mucize olarak) verdiği deveye ve onun su hakkına dokunmayın” demişti."
    },
    {
      "id": 14,
      "text": "",
      "translation": "Fakat onlar ona inanmayıp deveyi kestiler. Bunun üzerine rableri, günahları sebebiyle onlara ardı arkası kesilmez felaketler göndererek hepsini helak etti."
    },
    {
      "id": 15,
      "text": "",
      "translation": "O, yaptığının sonucundan korkacak değildir."
    },
    {
      "id": 0,
      "text": "",
      "translation": "Rahman ve rahim olan Allah'ın adıyla."
    },
    {
      "id": 0,
      "text": "",
      "translation": "Rahman ve rahim olan Allah'ın adıyla."
    }
  ]
}